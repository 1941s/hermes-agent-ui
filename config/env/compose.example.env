# -----------------------------------------------------------------------------
# Copy to repository ROOT as `.env` — Docker Compose + Next.js build-time public vars
# Do NOT put LLM API keys here; use apps/api/.env (see config/env/api.example.env)
# -----------------------------------------------------------------------------

# Docker profile: demo or prod
COMPOSE_PROFILES=demo

# Optional: domestic mirror base images (see README)
NODE_IMAGE=node:20-alpine
PYTHON_IMAGE=python:3.11-slim
NPM_REGISTRY=https://registry.npmjs.org

# Next.js embeds these at image build time (web service)
NEXT_PUBLIC_AGENT_WS_URL=ws://localhost:8000/ws/agent
NEXT_PUBLIC_AGENT_AUTH_TOKEN=

# Prod data plane (used when profile=prod)
POSTGRES_DB=hermes
POSTGRES_USER=hermes
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://hermes:change-me@postgres:5432/hermes
REDIS_URL=redis://redis:6379/0
