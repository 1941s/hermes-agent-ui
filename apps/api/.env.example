# OpenAI-compatible API (OpenAI / Azure / 阿里云 DashScope 兼容模式等)
# 设为真实 Key 后，API 会把它与 OPENAI_BASE_URL 显式传给 Hermes AIAgent，
# 避免在未配置时走 auxiliary 自动选路而误用 Anthropic（qwen 发到 api.anthropic.com 会 404）。
OPENAI_API_KEY=stub-openai-key
# 使用通义等 OpenAI 兼容网关时必填，例如 DashScope（二选一，以控制台「OpenAI 兼容」说明为准）：
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# OPENAI_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
# 若已指向 DashScope 仍出现 HTTP 401 / invalid_api_key：在阿里云控制台重新生成 API-Key、确认模型已开通与余额，
# 且 OPENAI_API_KEY 为「DashScope」的 sk- 密钥（勿混用其它产品的 Key）。
OPENAI_BASE_URL=

ANTHROPIC_API_KEY=stub-anthropic-key
# 若要用 OpenAI 兼容接口（如通义），请勿在环境里配置真实 Anthropic Key，
# 否则 hermes-agent 可能自动走 Anthropic 路由，导致模型名与端点不匹配（如 404）。

HERMES_PROVIDER=openai
HERMES_MODEL=gpt-4o-mini

HERMES_UI_AUTH_ENABLED=1
HERMES_UI_JWT_SECRET=replace-me
HERMES_UI_JWT_ISSUER=hermes-ui
HERMES_UI_JWT_AUDIENCE=hermes-web
