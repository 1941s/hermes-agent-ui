# Docker profile: demo or prod
COMPOSE_PROFILES=demo

# Shared auth/runtime
HERMES_UI_JWT_SECRET=replace-me
HERMES_UI_JWT_ISSUER=hermes-ui
HERMES_UI_JWT_AUDIENCE=hermes-web
OPENAI_API_KEY=stub-openai-key
ANTHROPIC_API_KEY=stub-anthropic-key
HERMES_PROVIDER=openai
HERMES_MODEL=gpt-4o-mini

# Web build-time vars
NEXT_PUBLIC_AGENT_WS_URL=ws://localhost:8000/ws/agent
NEXT_PUBLIC_AGENT_AUTH_TOKEN=

# Demo toggles
HERMES_UI_SKIP_AGENT_BOOT=0

# Prod data plane
POSTGRES_DB=hermes
POSTGRES_USER=hermes
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://hermes:change-me@postgres:5432/hermes
REDIS_URL=redis://redis:6379/0
