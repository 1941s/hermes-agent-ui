# Docker profile: demo or prod
COMPOSE_PROFILES=demo

# Optional: switch to a domestic mirror image to avoid Docker Hub proxy failures.
# Verified example mirrors:
# NODE_IMAGE=swr.cn-north-4.myhuaweicloud.com/ddn-k8s/docker.io/library/node:20-alpine
# PYTHON_IMAGE=swr.cn-north-4.myhuaweicloud.com/ddn-k8s/docker.io/library/python:3.11-slim
# NPM_REGISTRY=https://registry.npmmirror.com
NODE_IMAGE=node:20-alpine
PYTHON_IMAGE=python:3.11-slim
NPM_REGISTRY=https://registry.npmjs.org

# Shared auth/runtime
HERMES_UI_JWT_SECRET=replace-me
HERMES_UI_JWT_ISSUER=hermes-ui
HERMES_UI_JWT_AUDIENCE=hermes-web
# Model provider + model name are provided by Web UI settings at runtime.

# Web build-time vars
NEXT_PUBLIC_AGENT_WS_URL=ws://localhost:8000/ws/agent
NEXT_PUBLIC_AGENT_AUTH_TOKEN=

# Demo toggles
HERMES_UI_SKIP_AGENT_BOOT=0

# Prod data plane
POSTGRES_DB=hermes
POSTGRES_USER=hermes
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://hermes:change-me@postgres:5432/hermes
REDIS_URL=redis://redis:6379/0
